{
  "Logging": { "LogLevel": { "Default": "Warning" } },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/taskmanagement.AuthService/{**catch-all}" }
      },
      "project-route": {
        "ClusterId": "project-cluster",
        "Match": { "Path": "/taskmanagement.ProjectService/{**catch-all}" }
      },
      "task-route": {
        "ClusterId": "task-cluster",
        "Match": { "Path": "/taskmanagement.TaskService/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "d1": { "Address": "http://auth-service:5001/" } },
        "HttpClient": { "MaxConnectionsPerServer": 64 }
      },
      "project-cluster": {
        "Destinations": { "d1": { "Address": "http://project-service:5002/" } },
        "HttpClient": { "MaxConnectionsPerServer": 64 }
      },
      "task-cluster": {
        "Destinations": { "d1": { "Address": "http://task-service:5003/" } },
        "HttpClient": { "MaxConnectionsPerServer": 64 }
      }
    }
  }
}
